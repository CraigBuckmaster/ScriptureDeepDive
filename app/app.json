{
  "expo": {
    "name": "Companion Study",
    "slug": "companion-study",
    "version": "1.0.3",
    "orientation": "default",
    "icon": "./assets/images/icon-512.png",
    "scheme": "scripture",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0c0a07",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/images/icon-512.png",
      "resizeMode": "contain",
      "backgroundColor": "#0c0a07"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.companionstudy.app",
      "infoPlist": {
        "UIBackgroundModes": [ "audio" ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Used to centre the biblical map on your current location when you tap the locate control."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon-512.png",
        "backgroundColor": "#0c0a07"
      },
      "package": "com.scripturedeepive.app",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/images/icon-192.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": { "newArchEnabled": false },
          "android": { "newArchEnabled": false }
        }
      ],
      "expo-font",
      "expo-screen-orientation",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0c0a07"
        }
      ],
      "expo-asset",
      "expo-sqlite",
      "@maplibre/maplibre-react-native"
    ],
    "updates": {
      "url": "https://u.expo.dev/105f31ba-3cfb-4d35-8509-4abbe6ab132d",
      "enabled": false,
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "sentryDsn": "",
      "eas": {
        "projectId": "105f31ba-3cfb-4d35-8509-4abbe6ab132d"
      }
    },
    "owner": "skahz"
  }
}
