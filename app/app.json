{
  "expo": {
    "name": "Companion Study",
    "slug": "companion-study",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon-512.png",
    "scheme": "scripture",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0c0a07",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/images/icon-512.png",
      "resizeMode": "contain",
      "backgroundColor": "#0c0a07"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.scripturedeepive.app",
      "buildNumber": "1",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ]
      },
      "config": {
        "googleMapsApiKey": "GOOGLE_MAPS_API_KEY"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon-512.png",
        "backgroundColor": "#0c0a07"
      },
      "package": "com.scripturedeepive.app",
      "versionCode": 1,
      "config": {
        "googleMaps": {
          "apiKey": "GOOGLE_MAPS_API_KEY"
        }
      }
    },
    "web": {
      "favicon": "./assets/images/icon-192.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-screen-orientation",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0c0a07"
        }
      ],
      "expo-asset",
      "expo-sqlite",
      "@sentry/react-native/expo"
    ],
    "updates": {
      "url": "https://u.expo.dev/105f31ba-3cfb-4d35-8509-4abbe6ab132d",
      "enabled": true,
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "sentryDsn": "",
      "eas": {
        "projectId": "105f31ba-3cfb-4d35-8509-4abbe6ab132d"
      }
    },
    "owner": "skahz"
  }
}
