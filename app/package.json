{
  "name": "companion-study",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "setup": "node scripts/setup.js",
    "prestart": "node scripts/setup.js",
    "start": "node scripts/setup.js && expo start",
    "dev": "node scripts/setup.js && expo start --clear --go",
    "android": "node scripts/setup.js && expo start --android",
    "ios": "node scripts/setup.js && expo start --ios",
    "web": "node scripts/setup.js && expo start --web",
    "pre-update": "node scripts/pre-eas-update.js",
    "test": "jest",
    "lint": "eslint src/ --max-warnings 0",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "update": "node scripts/pre-eas-update.js && eas update --branch production"
  },
  "dependencies": {
    "@expo-google-fonts/cinzel": "^0.2.3",
    "@expo-google-fonts/eb-garamond": "^0.2.3",
    "@expo-google-fonts/source-sans-3": "^0.2.3",
    "@gorhom/bottom-sheet": "^5.1.1",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/stack": "^7.2.10",
    "d3-hierarchy": "^3.1.2",
    "expo": "^54.0.0",
    "expo-asset": "~12.0.12",
    "expo-auth-session": "~7.0.10",
    "expo-av": "^16.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-crypto": "~15.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-notifications": "~0.32.16",
    "expo-screen-orientation": "~9.0.8",
    "expo-sharing": "~14.0.8",
    "expo-speech": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-store-review": "~9.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "lucide-react-native": "^0.475.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "prettier": "^3.8.1",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "@tootallnate/once": ">=3.0.1"
