name: Content Pipeline

on:
  pull_request:
    branches: [master]
    paths:
      - 'content/**'
      - '_tools/**'
  push:
    branches: [master]
    paths:
      - 'content/**'
      - '_tools/**'

permissions:
  contents: read
  pull-requests: write
  issues: write

jobs:
  validate-and-build:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4
        with:
          lfs: false
          fetch-depth: 0  # Full history for diff

      - uses: actions/setup-python@v5
        with:
          python-version: '3.12'

      - name: Remove pre-built DB (build from scratch)
        run: rm -f scripture.db

      # ── Stage 1: Schema + DB (blocking) ──────────────────────

      - name: Validate content JSON
        id: validate_json
        run: |
          python3 _tools/schema_validator.py 2>&1 | tee validate_json.log
        continue-on-error: true

      - name: Build scripture.db
        id: build_db
        run: |
          python3 _tools/build_sqlite.py 2>&1 | tee build_db.log
        continue-on-error: true

      - name: Validate scripture.db integrity
        id: validate_db
        run: |
          python3 _tools/validate_sqlite.py 2>&1 | tee validate_db.log
        continue-on-error: true

      # ── Stage 2: Detect changed chapters ─────────────────────

      - name: Detect changed content
        id: changes
        if: github.event_name == 'pull_request'
        run: |
          CHANGED=$(git diff --name-only ${{ github.event.pull_request.base.sha }} HEAD \
            -- 'content/*/[0-9]*.json' 2>/dev/null | sort)

          if [ -z "$CHANGED" ]; then
            echo "has_content_changes=false" >> $GITHUB_OUTPUT
            echo "No chapter content changes detected"
          else
            COUNT=$(echo "$CHANGED" | wc -l)
            echo "has_content_changes=true" >> $GITHUB_OUTPUT
            echo "changed_files<<ENDFILES" >> $GITHUB_OUTPUT
            echo "$CHANGED" >> $GITHUB_OUTPUT
            echo "ENDFILES" >> $GITHUB_OUTPUT
            echo "change_count=$COUNT" >> $GITHUB_OUTPUT
            echo "Changed chapters: $COUNT"
            echo "$CHANGED"
          fi

      # ── Stage 3: Quality + Accuracy checks ───────────────────

      - name: Run content quality + accuracy checks
        id: content_check
        if: >
          github.event_name == 'pull_request' &&
          steps.changes.outputs.has_content_changes == 'true'
        env:
          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
        run: |
          # Determine tier based on API key availability
          if [ -n "$ANTHROPIC_API_KEY" ]; then
            TIER=2
            echo "Tier 2 enabled (API key configured)"
          else
            TIER=1
            echo "Tier 1 only (no API key — add ANTHROPIC_API_KEY secret for Tier 2)"
          fi

          # Write .env for the accuracy auditor
          if [ -n "$ANTHROPIC_API_KEY" ]; then
            echo "ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY" > _tools/.env
          fi

          # Run the orchestrator
          echo "${{ steps.changes.outputs.changed_files }}" | \
            python3 _tools/ci_content_check.py --stdin --tier $TIER > ci_output.json 2>ci_stderr.log

          CI_EXIT=$?
          echo "ci_exit_code=$CI_EXIT" >> $GITHUB_OUTPUT

          # Extract summary markdown for PR comment
          SUMMARY_MD=$(python3 -c "
          import json
          data = json.load(open('ci_output.json'))
          print(data.get('summary_markdown', ''))
          ")

          EOF=$(dd if=/dev/urandom bs=15 count=1 status=none | base64)
          echo "summary<<$EOF" >> $GITHUB_OUTPUT
          echo "$SUMMARY_MD" >> $GITHUB_OUTPUT
          echo "$EOF" >> $GITHUB_OUTPUT

          # Extract issues to create
          ISSUES=$(python3 -c "
          import json
          data = json.load(open('ci_output.json'))
          issues = data.get('issues_to_create', [])
          print(json.dumps(issues))
          ")
          echo "issues=$ISSUES" >> $GITHUB_OUTPUT

          # Extract status
          STATUS=$(python3 -c "
          import json
          data = json.load(open('ci_output.json'))
          print(data.get('status', 'pass'))
          ")
          echo "status=$STATUS" >> $GITHUB_OUTPUT

          # Show stderr (progress messages)
          cat ci_stderr.log

          exit $CI_EXIT
        continue-on-error: true

      # ── Stage 4: Generate combined summary ───────────────────

      - name: Generate pipeline summary
        if: always()
        id: summary
        run: |
          JSON_STATUS="${{ steps.validate_json.outcome }}"
          BUILD_STATUS="${{ steps.build_db.outcome }}"
          DB_STATUS="${{ steps.validate_db.outcome }}"
          CONTENT_STATUS="${{ steps.content_check.outputs.status }}"

          # Extract pass/fail counts
          JSON_RESULTS=""
          if [ -f validate_json.log ]; then
            JSON_RESULTS=$(grep -oP 'RESULTS: \K\d+ passed, \d+ failed' validate_json.log || echo "unknown")
          fi

          DB_RESULTS=""
          if [ -f validate_db.log ]; then
            DB_RESULTS=$(grep -oP 'RESULTS: \K\d+ passed, \d+ failed' validate_db.log || echo "unknown")
          fi

          status_icon() {
            if [ "$1" = "success" ]; then echo "✅"; else echo "❌"; fi
          }

          # Overall status
          OVERALL="✅ All pipeline checks passed"
          if [ "$JSON_STATUS" != "success" ] || [ "$BUILD_STATUS" != "success" ] || [ "$DB_STATUS" != "success" ]; then
            OVERALL="❌ Pipeline has failures"
          elif [ "$CONTENT_STATUS" = "fail" ]; then
            OVERALL="❌ Content check found hard errors"
          elif [ "$CONTENT_STATUS" = "warn" ]; then
            OVERALL="⚠️ Content check found warnings"
          fi

          # Build the body
          BODY="## Content Pipeline Results

          ${OVERALL}

          | Step | Status | Details |
          |---|---|---|
          | **Schema Validation** | $(status_icon $JSON_STATUS) | ${JSON_RESULTS:-—} |
          | **Build DB** | $(status_icon $BUILD_STATUS) | — |
          | **DB Integrity** | $(status_icon $DB_STATUS) | ${DB_RESULTS:-—} |"

          # Append content check summary if it ran
          CONTENT_SUMMARY="${{ steps.content_check.outputs.summary }}"
          if [ -n "$CONTENT_SUMMARY" ]; then
            BODY="$BODY

          ---

          $CONTENT_SUMMARY"
          fi

          echo "$BODY" >> $GITHUB_STEP_SUMMARY

          EOF=$(dd if=/dev/urandom bs=15 count=1 status=none | base64)
          echo "body<<$EOF" >> $GITHUB_OUTPUT
          echo "$BODY" >> $GITHUB_OUTPUT
          echo "$EOF" >> $GITHUB_OUTPUT

      # ── Stage 5: Post PR comment ─────────────────────────────

      - name: Post results to PR
        if: always() && github.event_name == 'pull_request'
        uses: actions/github-script@v7
        with:
          script: |
            const body = `${{ steps.summary.outputs.body }}`;
            if (!body) return;

            const { data: comments } = await github.rest.issues.listComments({
              owner: context.repo.owner,
              repo: context.repo.repo,
              issue_number: context.issue.number,
            });
            const botComment = comments.find(c =>
              c.user.type === 'Bot' && c.body.includes('## Content Pipeline Results')
            );

            if (botComment) {
              await github.rest.issues.updateComment({
                owner: context.repo.owner,
                repo: context.repo.repo,
                comment_id: botComment.id,
                body,
              });
            } else {
              await github.rest.issues.createComment({
                owner: context.repo.owner,
                repo: context.repo.repo,
                issue_number: context.issue.number,
                body,
              });
            }

      # ── Stage 6: Create issues for warnings ─────────────────

      - name: Create issues for content warnings
        if: >
          always() && github.event_name == 'pull_request' &&
          steps.content_check.outputs.issues != '[]' &&
          steps.content_check.outputs.issues != ''
        uses: actions/github-script@v7
        with:
          script: |
            const issuesJson = `${{ steps.content_check.outputs.issues }}`;
            if (!issuesJson || issuesJson === '[]') return;

            let issues;
            try {
              issues = JSON.parse(issuesJson);
            } catch (e) {
              console.log('Failed to parse issues JSON:', e);
              return;
            }

            for (const issue of issues) {
              // Check for duplicate (same title already open)
              const { data: existing } = await github.rest.issues.listForRepo({
                owner: context.repo.owner,
                repo: context.repo.repo,
                state: 'open',
                labels: issue.labels.join(','),
              });

              const duplicate = existing.find(e => e.title === issue.title);
              if (duplicate) {
                console.log(`Skipping duplicate: ${issue.title} (#${duplicate.number})`);
                continue;
              }

              const { data: created } = await github.rest.issues.create({
                owner: context.repo.owner,
                repo: context.repo.repo,
                title: issue.title,
                body: issue.body,
                labels: issue.labels,
              });
              console.log(`Created issue: ${issue.title} (#${created.number})`);
            }

      # ── Stage 7: Final gate ──────────────────────────────────

      - name: Check for blocking failures
        if: always()
        run: |
          FAILED=false

          if [ "${{ steps.validate_json.outcome }}" != "success" ]; then
            echo "❌ Schema validation failed"
            FAILED=true
          fi

          if [ "${{ steps.build_db.outcome }}" != "success" ]; then
            echo "❌ DB build failed"
            FAILED=true
          fi

          if [ "${{ steps.validate_db.outcome }}" != "success" ]; then
            echo "❌ DB integrity check failed"
            FAILED=true
          fi

          # Content check hard errors block the PR
          if [ "${{ steps.content_check.outputs.status }}" = "fail" ]; then
            echo "❌ Content check found hard errors (REFUTED claims)"
            FAILED=true
          fi

          # Content check warnings do NOT block (issues created instead)
          if [ "${{ steps.content_check.outputs.status }}" = "warn" ]; then
            echo "⚠️ Content check found warnings (issues created)"
          fi

          if [ "$FAILED" = "true" ]; then
            echo "One or more blocking checks failed"
            exit 1
          fi
