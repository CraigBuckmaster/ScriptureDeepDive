    {
      "id": "restoration",
      "order": 8,
      "name": "Restoration",
      "tagline": "God makes all things new",
      "era_ids": [
        "apocalyptic"
      ],
      "book_range": "Revelation",
      "summary": "The Revelation of Jesus Christ brings the biblical narrative to its consummation. The Lamb who was slain conquers through sacrifice, Babylon falls, the beast is defeated, and the final judgment clears the stage for a new heaven and new earth. The tree of life, lost in Eden, stands in the new Jerusalem. The curse of Genesis 3 is reversed. God dwells permanently with redeemed humanity, every tear is wiped away, and the story that began with 'In the beginning God created' ends with 'Come, Lord Jesus.'",
      "key_verse": {
        "ref": "Rev 21:5",
        "text": "He who was seated on the throne said, 'I am making everything new!'"
      },
