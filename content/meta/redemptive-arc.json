    {
      "id": "incarnation",
      "order": 6,
      "name": "Incarnation",
      "tagline": "The Word becomes flesh",
      "era_ids": [
        "life_of_christ"
      ],
      "book_range": "Matthew – John",
      "summary": "God breaks four centuries of silence by entering history as a human being. Jesus of Nazareth announces the kingdom of God, demonstrates it through signs and teaching, and accomplishes salvation through his death and resurrection. Every Old Testament thread converges in him: he is the seed of the woman, the Passover lamb, the prophet like Moses, the Davidic king, the suffering servant, the new covenant mediator. The resurrection vindicates his claims and inaugurates the new creation.",
      "key_verse": {
        "ref": "John 1:14",
        "text": "The Word became flesh and made his dwelling among us. We have seen his glory, the glory of the one and only Son, who came from the Father, full of grace and truth."
      },
