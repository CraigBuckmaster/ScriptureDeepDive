    {
      "id": "mission",
      "order": 7,
      "name": "Mission",
      "tagline": "The Spirit is poured out, the church is sent",
      "era_ids": [
        "early_church",
        "pauline_mission",
        "general_epistles"
      ],
      "book_range": "Acts – Jude",
      "summary": "The Holy Spirit descends at Pentecost, and the church explodes from Jerusalem to the ends of the earth. Paul's missionary journeys and letters define Christian theology — justification by faith, Jew-Gentile unity, the body of Christ. The general epistles address the church's second-generation challenges: persecution, false teaching, and the delay of Christ's return. The Abrahamic promise that all nations would be blessed finds its fulfillment as the gospel crosses every boundary of ethnicity, culture, and class.",
      "key_verse": {
        "ref": "Acts 1:8",
        "text": "But you will receive power when the Holy Spirit comes on you; and you will be my witnesses in Jerusalem, and in all Judea and Samaria, and to the ends of the earth."
      },
