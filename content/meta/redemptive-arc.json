{
  "schema_version": "1.0",
  "description": "The Bible's redemptive meta-narrative in 8 acts, with chapter-level mapping",
  "acts": [
    {
      "id": "creation",
      "order": 1,
      "name": "Creation",
      "tagline": "God makes a world and calls it good",
      "era_ids": [
        "primeval"
      ],
      "book_range": "Genesis 1–2",
      "summary": "God creates the heavens and the earth, fashions humanity in his own image, and establishes the garden of Eden as the place of intimate communion. Everything is declared 'very good' — a world of order, beauty, purpose, and unbroken relationship between Creator and creature. Humanity is given the vocation of stewarding creation and multiplying God's presence throughout the earth.",
      "key_verse": {
        "ref": "Gen 1:31",
        "text": "God saw all that he had made, and it was very good."
      },
      "threads": [
        "creation-new-creation",
        "image-of-god",
        "rest-sabbath",
        "tree-of-life"
      ],
      "prophecy_chains": []
    },
    {
      "id": "rebellion",
      "order": 2,
      "name": "Rebellion",
      "tagline": "Humanity chooses autonomy over trust",
      "era_ids": [
        "primeval"
      ],
      "book_range": "Genesis 3–11",
      "summary": "The serpent's deception and humanity's choice to grasp autonomy fracture every relationship — with God, with each other, and with creation itself. Sin escalates rapidly from the garden to Cain's murder, to Lamech's vengeance, to the violence that provokes the flood. Even after the flood's reset, Babel reveals that the human heart remains unchanged. Yet in the midst of judgment, God plants seeds of promise: the seed of the woman will crush the serpent, and through one family the curse will begin to be reversed.",
      "key_verse": {
        "ref": "Gen 3:15",
        "text": "And I will put enmity between you and the woman, and between your offspring and hers; he will crush your head, and you will strike his heel."
      },
      "threads": [
        "substitutionary-sacrifice",
        "judgment-mercy",
        "light-darkness"
      ],
      "prophecy_chains": [
        "seed_of_woman",
        "noahic_covenant"
      ]
    },
    {
      "id": "promise",
      "order": 3,
      "name": "Promise",
      "tagline": "God chooses a family to bless all nations",
      "era_ids": [
        "patriarch",
        "exodus"
      ],
      "book_range": "Genesis 12 – Deuteronomy",
      "summary": "God calls Abraham and makes a covenant of land, descendants, and universal blessing. Across four generations the promise is tested and preserved. When Abraham's descendants are enslaved in Egypt, God delivers them through the exodus — the defining act of Old Testament salvation. At Sinai, God gives the law and establishes the tabernacle so he can dwell among his people. The wilderness generation fails to trust God, but Moses prepares a new generation to enter the promised land.",
      "key_verse": {
        "ref": "Gen 12:3",
        "text": "I will bless those who bless you, and whoever curses you I will curse; and all peoples on earth will be blessed through you."
      },
      "threads": [
        "covenant-thread",
        "substitutionary-sacrifice",
        "temple-dwelling",
        "law-torah",
        "bread-manna",
        "water-living-water",
        "shepherd-motif"
      ],
      "prophecy_chains": [
        "abrahamic_covenant",
        "mosaic_covenant",
        "passover_lamb",
        "tabernacle_temple",
        "manna_from_heaven",
        "bronze_serpent",
        "prophet_like_moses",
        "isaac_sacrifice",
        "joseph_type",
        "moses_deliverer",
        "adam_type_of_christ",
        "cities_of_refuge",
        "firstfruits",
        "sabbath_rest",
        "day_of_atonement"
      ]
    },
    {
      "id": "kingdom",
      "order": 4,
      "name": "Kingdom",
      "tagline": "God gives Israel a land, a throne, and a temple",
      "era_ids": [
        "judges",
        "kingdom",
        "divided_kingdom"
      ],
      "book_range": "Joshua – 2 Chronicles",
      "summary": "Israel conquers Canaan, cycles through the judges period, and eventually receives a king. David's reign and God's covenant with him — an eternal dynasty, kingdom, and throne — become the foundation of all messianic expectation. Solomon builds the temple where God's glory dwells. But the kingdom fractures after Solomon, and the divided monarchy descends through cycles of reform and apostasy. The wisdom literature and psalms of this era explore what life under God's rule looks like in practice.",
      "key_verse": {
        "ref": "2 Sam 7:16",
        "text": "Your house and your kingdom will endure forever before me; your throne will be established forever."
      },
      "threads": [
        "kingdom-of-god",
        "davidic-king",
        "temple-dwelling",
        "shepherd-motif",
        "wisdom-thread",
        "faithful-suffering",
        "women-of-faith",
        "rest-sabbath"
      ],
      "prophecy_chains": [
        "davidic_covenant",
        "scepter_from_judah",
        "david_shepherd_king",
        "kinsman_redeemer"
      ]
    },
    {
      "id": "exile",
      "order": 5,
      "name": "Exile",
      "tagline": "Consequences of unfaithfulness and the promise of return",
      "era_ids": [
        "prophets",
        "exile",
        "post-exilic",
        "intertestamental"
      ],
      "book_range": "Isaiah – Malachi",
      "summary": "The prophets indict Israel's covenant violations, announce judgment, and plant seeds of hope for a restoration that will surpass anything Israel has known. Babylon destroys Jerusalem and its temple, carrying the population into exile. The crisis forces Israel to reimagine faith without land, king, or temple. A remnant returns and rebuilds, but the second temple's modest glory and continued foreign domination make clear that the greater restoration — a new covenant, a suffering servant, a Spirit-outpouring — is still to come. Four centuries of prophetic silence follow.",
      "key_verse": {
        "ref": "Jer 31:33",
        "text": "I will put my law in their minds and write it on their hearts. I will be their God, and they will be my people."
      },
      "threads": [
        "exile-return",
