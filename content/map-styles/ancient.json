{
  "version": 8,
  "name": "Companion Study — Ancient World",
  "metadata": {
    "maplibre:renderer": "mlgljs",
    "companion-study:variant": "ancient",
    "companion-study:description": "Sepia/parchment aesthetic for biblical-era maps. No modern labels, roads, or POIs — only coastlines, terrain, water, and hillshading. Our own place labels are layered on top by the app."
  },
  "glyphs": "https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf",
  "sources": {
    "openfree": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet"
    },
    "terrain-dem": {
      "type": "raster-dem",
      "tiles": [
        "https://s3.amazonaws.com/elevation-tiles-prod/terrarium/{z}/{x}/{y}.png"
      ],
      "tileSize": 256,
      "encoding": "terrarium",
      "maxzoom": 15
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#d4c4a0"
      }
    },
    {
      "id": "landcover-forest",
      "type": "fill",
      "source": "openfree",
      "source-layer": "landcover",
      "filter": ["==", ["get", "class"], "wood"],
      "paint": {
        "fill-color": "#c4b28a",
        "fill-opacity": 0.35
      }
    },
    {
      "id": "landcover-sand",
      "type": "fill",
      "source": "openfree",
      "source-layer": "landcover",
      "filter": ["==", ["get", "class"], "sand"],
      "paint": {
        "fill-color": "#e6d5a8",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "landcover-grass",
      "type": "fill",
      "source": "openfree",
      "source-layer": "landcover",
      "filter": ["==", ["get", "class"], "grass"],
      "paint": {
        "fill-color": "#cfbe92",
        "fill-opacity": 0.4
      }
    },
    {
      "id": "hillshade",
      "type": "hillshade",
      "source": "terrain-dem",
      "maxzoom": 15,
      "paint": {
        "hillshade-exaggeration": 0.45,
        "hillshade-shadow-color": "#6b4e23",
        "hillshade-highlight-color": "#f1e3c0",
        "hillshade-accent-color": "#8b6a3a",
        "hillshade-illumination-direction": 335
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openfree",
      "source-layer": "water",
      "paint": {
        "fill-color": "#7a9cb8",
        "fill-opacity": 0.9
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openfree",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#7a9cb8",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          6, 0.4,
          12, 1.5,
          16, 3
        ]
      }
    },
    {
      "id": "coastline",
      "type": "line",
      "source": "openfree",
      "source-layer": "water",
      "paint": {
        "line-color": "#8b6a3a",
        "line-width": 1.5,
        "line-opacity": 0.8
      }
    }
  ]
}
