{
  "version": 8,
  "name": "Companion Study — Modern Context",
  "metadata": {
    "maplibre:renderer": "mlgljs",
    "companion-study:variant": "modern",
    "companion-study:description": "Same sepia terrain as ancient.json with modern country borders + country-name labels layered on top — contextualises biblical events within today's world. POIs, roads, and admin sub-regions remain suppressed."
  },
  "glyphs": "https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf",
  "sources": {
    "openfree": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet"
    },
    "terrain-dem": {
      "type": "raster-dem",
      "tiles": [
        "https://s3.amazonaws.com/elevation-tiles-prod/terrarium/{z}/{x}/{y}.png"
      ],
      "tileSize": 256,
      "encoding": "terrarium",
      "maxzoom": 15
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#d4c4a0"
      }
    },
    {
      "id": "landcover-forest",
      "type": "fill",
      "source": "openfree",
      "source-layer": "landcover",
      "filter": ["==", ["get", "class"], "wood"],
      "paint": {
        "fill-color": "#c4b28a",
        "fill-opacity": 0.35
      }
    },
    {
      "id": "landcover-sand",
      "type": "fill",
      "source": "openfree",
      "source-layer": "landcover",
      "filter": ["==", ["get", "class"], "sand"],
      "paint": {
        "fill-color": "#e6d5a8",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "landcover-grass",
      "type": "fill",
      "source": "openfree",
      "source-layer": "landcover",
      "filter": ["==", ["get", "class"], "grass"],
      "paint": {
        "fill-color": "#cfbe92",
        "fill-opacity": 0.4
      }
    },
    {
      "id": "hillshade",
      "type": "hillshade",
      "source": "terrain-dem",
      "maxzoom": 15,
      "paint": {
        "hillshade-exaggeration": 0.45,
        "hillshade-shadow-color": "#6b4e23",
        "hillshade-highlight-color": "#f1e3c0",
        "hillshade-accent-color": "#8b6a3a",
        "hillshade-illumination-direction": 335
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openfree",
      "source-layer": "water",
      "paint": {
        "fill-color": "#7a9cb8",
        "fill-opacity": 0.9
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openfree",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#7a9cb8",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          6, 0.4,
          12, 1.5,
          16, 3
        ]
      }
    },
    {
      "id": "coastline",
      "type": "line",
      "source": "openfree",
      "source-layer": "water",
      "paint": {
        "line-color": "#8b6a3a",
        "line-width": 1.5,
        "line-opacity": 0.8
      }
    },
    {
      "id": "boundary-country",
      "type": "line",
      "source": "openfree",
      "source-layer": "boundary",
      "filter": ["all", ["==", ["get", "admin_level"], 2], ["!=", ["get", "maritime"], 1]],
      "paint": {
        "line-color": "#bfa050",
        "line-opacity": 0.38,
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          2, 0.6,
          6, 1,
          10, 1.4
        ],
        "line-dasharray": [4, 2]
      }
    },
    {
      "id": "place-country-label",
      "type": "symbol",
      "source": "openfree",
      "source-layer": "place",
      "filter": ["==", ["get", "class"], "country"],
      "minzoom": 3,
      "maxzoom": 8,
      "layout": {
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Italic"],
        "text-size": [
          "interpolate", ["linear"], ["zoom"],
          3, 10,
          6, 14,
          8, 17
        ],
        "text-letter-spacing": 0.1,
        "text-max-width": 7,
        "text-transform": "uppercase"
      },
      "paint": {
        "text-color": "#c8baa8",
        "text-halo-color": "#3d2e17",
        "text-halo-width": 1.2,
        "text-opacity": 0.9
      }
    },
    {
      "id": "water-body-label",
      "type": "symbol",
      "source": "openfree",
      "source-layer": "water_name",
      "minzoom": 3,
      "layout": {
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Italic"],
        "text-size": [
          "interpolate", ["linear"], ["zoom"],
          3, 10,
          6, 13,
          10, 16
        ],
        "text-max-width": 7
      },
      "paint": {
        "text-color": "#4a6a80",
        "text-halo-color": "#d4c4a0",
        "text-halo-width": 1,
        "text-opacity": 0.85
      }
    }
  ]
}
